    "\n",
    "engine = create_engine(\n",
    "    'postgresql+psycopg://postgres:postgres@db:5432/mobility'\n",
    ")\n",
    "\n",
    "with engine.begin() as conn:\n",
    "    conn.execute(text(\n",
    "        '''\n",
    "        DROP TABLE roads;\n",
    "        '''\n",
    "    ))"
   ]
  }
